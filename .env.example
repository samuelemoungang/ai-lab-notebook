# ── Anthropic (Claude) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Optional: local Qwen/Ollama endpoint ─────────────────────────────────────
# Leave empty to always use Claude
# Set to e.g. http://192.168.1.10:11434 when your home PC is reachable
NEXT_PUBLIC_OLLAMA_URL=
NEXT_PUBLIC_OLLAMA_MODEL=qwen2.5-coder:14b
